#!/bin/bash
# Toggle voice_client on/off - bind this to a hotkey

# Set environment for non-interactive sessions (e.g., keyboard shortcuts)
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export PULSE_SERVER="${PULSE_SERVER:-unix:$XDG_RUNTIME_DIR/pulse/native}"
export YDOTOOL_SOCKET="${YDOTOOL_SOCKET:-/tmp/.ydotool_socket}"

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PIDFILE="/tmp/voice_client.pid"

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    # Running - kill it
    kill "$(cat "$PIDFILE")"
    rm -f "$PIDFILE"
    echo "Stopped"
else
    # Not running - start it
    "$SCRIPT_DIR/voice_client" &
    echo "Started"
fi
